---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { CATEGORIES } from '../../consts';
import { withBase } from '../../utils/url';

const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const breadcrumbs = [
  { name: 'ホーム', url: '/' },
  { name: '記事一覧', url: '/articles' },
];
---

<BaseLayout
  title="記事一覧"
  description="家族の見守り・安否確認・防災に関するすべての記事の一覧です。高齢者の見守りから子どもの安全、見守りアプリの活用法まで幅広く解説しています。"
  canonical="/articles"
  breadcrumbs={breadcrumbs}
>
  <div class="container section">
    <header class="page-head">
      <h1>記事一覧</h1>
      <p>家族の見守りに役立つ記事をすべて掲載しています（全{articles.length}件）。</p>
    </header>

    <nav class="cat-filter" aria-label="カテゴリーで絞り込み">
      {
        CATEGORIES.map((c) => (
          <a href={withBase(`/categories/${c.slug}`)} class="cat-chip">
            {c.emoji} {c.name}
          </a>
        ))
      }
    </nav>

    <div class="article-grid">
      {articles.map((a) => <ArticleCard article={a} />)}
    </div>
  </div>
</BaseLayout>

<style>
  .section {
    padding: 2.5rem 20px;
  }
  .page-head h1 {
    font-size: 1.9rem;
    margin: 0 0 0.4rem;
  }
  .page-head p {
    color: var(--color-text-muted);
    margin: 0 0 1.5rem;
  }
  .cat-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2rem;
  }
  .cat-chip {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary-dark);
    background: var(--color-primary-light);
    padding: 0.4em 1em;
    border-radius: 999px;
  }
  .cat-chip:hover {
    text-decoration: none;
    background: #d3e8e2;
  }
  .article-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.3rem;
  }
</style>
