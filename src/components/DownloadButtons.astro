---
import {
  APP_NAME,
  APP_TAGLINE,
  APP_DESCRIPTION,
  APP_IOS_URL,
  APP_ANDROID_URL,
} from '../consts';

interface Props {
  /** "full" = boxed CTA with description, "compact" = just buttons. */
  variant?: 'full' | 'compact';
  heading?: string;
}

const { variant = 'full', heading } = Astro.props;
---

{
  variant === 'full' ? (
    <section class="app-cta" aria-label={`${APP_NAME} のダウンロード`}>
      <div class="app-cta-inner">
        <p class="app-eyebrow">見守りアプリ</p>
        <h2 class="app-name">{heading ?? APP_NAME}</h2>
        <p class="app-tagline">{APP_TAGLINE}</p>
        <p class="app-desc">{APP_DESCRIPTION}</p>
        <div class="store-buttons">
          <a
            class="store-btn store-ios"
            href={APP_IOS_URL}
            target="_blank"
            rel="noopener"
          >
            <span aria-hidden="true"></span>
            <span>
              <small>Download on the</small>
              App Store
            </span>
          </a>
          <a
            class="store-btn store-android"
            href={APP_ANDROID_URL}
            target="_blank"
            rel="noopener"
          >
            <span aria-hidden="true">▶</span>
            <span>
              <small>GET IT ON</small>
              Google Play
            </span>
          </a>
        </div>
      </div>
    </section>
  ) : (
    <div class="store-buttons store-buttons--compact">
      <a class="store-btn store-ios" href={APP_IOS_URL} target="_blank" rel="noopener">
        <span aria-hidden="true"></span>
        <span><small>Download on the</small>App Store</span>
      </a>
      <a
        class="store-btn store-android"
        href={APP_ANDROID_URL}
        target="_blank"
        rel="noopener"
      >
        <span aria-hidden="true">▶</span>
        <span><small>GET IT ON</small>Google Play</span>
      </a>
    </div>
  )
}

<style>
  .app-cta {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    border-radius: var(--radius);
    color: #fff;
    padding: 2.4rem 1.6rem;
    margin: 2.5rem 0;
    text-align: center;
    box-shadow: 0 10px 30px rgba(35, 94, 81, 0.25);
  }
  .app-cta-inner {
    max-width: 560px;
    margin-inline: auto;
  }
  .app-eyebrow {
    display: inline-block;
    margin: 0;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    background: rgba(255, 255, 255, 0.18);
    padding: 0.3em 0.9em;
    border-radius: 999px;
  }
  .app-name {
    font-size: 1.6rem;
    margin: 0.7rem 0 0.3rem;
    border: none;
    color: #fff;
  }
  .app-tagline {
    font-weight: 700;
    margin: 0 0 1rem;
    color: #eafff8;
  }
  .app-desc {
    font-size: 0.92rem;
    line-height: 1.8;
    color: #dcefe9;
    margin: 0 0 1.6rem;
  }
  .store-buttons {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .store-buttons--compact {
    margin: 1.5rem 0;
  }
  .store-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #111;
    color: #fff;
    padding: 0.7rem 1.3rem;
    border-radius: 10px;
    min-width: 180px;
    transition: transform 0.12s ease, opacity 0.12s ease;
  }
  .store-btn:hover {
    text-decoration: none;
    transform: translateY(-2px);
    opacity: 0.92;
  }
  .store-btn > span:first-child {
    font-size: 1.5rem;
    line-height: 1;
  }
  .store-btn > span:last-child {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
    font-weight: 700;
    font-size: 1.05rem;
    text-align: left;
  }
  .store-btn small {
    font-size: 0.62rem;
    font-weight: 500;
    opacity: 0.85;
  }
  .store-buttons--compact .store-btn {
    background: var(--color-text);
  }
</style>
