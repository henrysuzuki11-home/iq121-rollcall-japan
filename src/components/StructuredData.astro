---
import { SITE_URL, SITE_NAME, SITE_DESCRIPTION, AUTHOR } from '../consts';
import { withBase } from '../utils/url';

type Crumb = { name: string; url: string };

interface Props {
  type: 'website' | 'article';
  title?: string;
  description?: string;
  url?: string;
  publishDate?: Date;
  modifiedDate?: Date;
  author?: string;
  breadcrumbs?: Crumb[];
}

const {
  type,
  title,
  description,
  url,
  publishDate,
  modifiedDate,
  author = AUTHOR,
  breadcrumbs = [],
} = Astro.props;

// Build absolute URLs that include both the origin and the base path.
const abs = (path: string) => new URL(withBase(path), SITE_URL).href;
const homeURL = abs('/');

const pageURL = url ? abs(url) : homeURL;

const organization = {
  '@type': 'Organization',
  '@id': `${homeURL}#organization`,
  name: SITE_NAME,
  url: homeURL,
  logo: {
    '@type': 'ImageObject',
    url: abs('/favicon.svg'),
  },
};

const website = {
  '@type': 'WebSite',
  '@id': `${homeURL}#website`,
  name: SITE_NAME,
  description: SITE_DESCRIPTION,
  url: homeURL,
  inLanguage: 'ja-JP',
  publisher: { '@id': `${homeURL}#organization` },
};

const graph: Record<string, unknown>[] = [organization, website];

if (type === 'article' && title) {
  graph.push({
    '@type': 'Article',
    headline: title,
    description,
    inLanguage: 'ja-JP',
    url: pageURL,
    mainEntityOfPage: { '@type': 'WebPage', '@id': pageURL },
    datePublished: publishDate?.toISOString(),
    dateModified: (modifiedDate ?? publishDate)?.toISOString(),
    author: { '@type': 'Organization', name: author, url: homeURL },
    publisher: { '@id': `${homeURL}#organization` },
  });
}

if (breadcrumbs.length > 0) {
  graph.push({
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((crumb, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: crumb.name,
      item: abs(crumb.url),
    })),
  });
}

const jsonLd = { '@context': 'https://schema.org', '@graph': graph };
---

<script
  type="application/ld+json"
  set:html={JSON.stringify(jsonLd)}
  is:inline
/>
