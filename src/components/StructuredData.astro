---
import { SITE_URL, SITE_NAME, SITE_DESCRIPTION, AUTHOR } from '../consts';

type Crumb = { name: string; url: string };

interface Props {
  type: 'website' | 'article';
  title?: string;
  description?: string;
  url?: string;
  publishDate?: Date;
  modifiedDate?: Date;
  author?: string;
  breadcrumbs?: Crumb[];
}

const {
  type,
  title,
  description,
  url,
  publishDate,
  modifiedDate,
  author = AUTHOR,
  breadcrumbs = [],
} = Astro.props;

const pageURL = url ? new URL(url, SITE_URL).href : SITE_URL;

const organization = {
  '@type': 'Organization',
  '@id': `${SITE_URL}/#organization`,
  name: SITE_NAME,
  url: SITE_URL,
  logo: {
    '@type': 'ImageObject',
    url: new URL('/favicon.svg', SITE_URL).href,
  },
};

const website = {
  '@type': 'WebSite',
  '@id': `${SITE_URL}/#website`,
  name: SITE_NAME,
  description: SITE_DESCRIPTION,
  url: SITE_URL,
  inLanguage: 'ja-JP',
  publisher: { '@id': `${SITE_URL}/#organization` },
};

const graph: Record<string, unknown>[] = [organization, website];

if (type === 'article' && title) {
  graph.push({
    '@type': 'Article',
    headline: title,
    description,
    inLanguage: 'ja-JP',
    url: pageURL,
    mainEntityOfPage: { '@type': 'WebPage', '@id': pageURL },
    datePublished: publishDate?.toISOString(),
    dateModified: (modifiedDate ?? publishDate)?.toISOString(),
    author: { '@type': 'Organization', name: author, url: SITE_URL },
    publisher: { '@id': `${SITE_URL}/#organization` },
  });
}

if (breadcrumbs.length > 0) {
  graph.push({
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((crumb, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: crumb.name,
      item: new URL(crumb.url, SITE_URL).href,
    })),
  });
}

const jsonLd = { '@context': 'https://schema.org', '@graph': graph };
---

<script
  type="application/ld+json"
  set:html={JSON.stringify(jsonLd)}
  is:inline
/>
