---
interface Crumb {
  name: string;
  url: string;
}
interface Props {
  crumbs: Crumb[];
}
import { withBase } from '../utils/url';
const { crumbs } = Astro.props;
---

<nav class="breadcrumbs" aria-label="パンくずリスト">
  <ol>
    {
      crumbs.map((crumb, i) => (
        <li>
          {i < crumbs.length - 1 ? (
            <a href={withBase(crumb.url)}>{crumb.name}</a>
          ) : (
            <span aria-current="page">{crumb.name}</span>
          )}
        </li>
      ))
    }
  </ol>
</nav>

<style>
  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    list-style: none;
    margin: 1.2rem 0;
    padding: 0;
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }
  .breadcrumbs li:not(:last-child)::after {
    content: '›';
    margin-left: 0.5rem;
    color: var(--color-text-muted);
  }
  .breadcrumbs a {
    color: var(--color-text-muted);
  }
  .breadcrumbs a:hover {
    color: var(--color-primary-dark);
  }
  .breadcrumbs span[aria-current] {
    color: var(--color-text);
    font-weight: 600;
  }
</style>
